FROM python:3.11-slim

WORKDIR /app

# Install system dependencies required for OpenCV and pycolmap
RUN apt-get update && apt-get install -y \
    libgl1-mesa-glx \
    libglib2.0-0 \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Used as a CLI runner
CMD ["python", "--version"]
